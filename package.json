{
  "name": "films-by-mj",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --kill-others --names \"ANGULAR,API\" --prefix-colors \"cyan,yellow\" \"npm run ng:serve\" \"node api-server.js\"",
    "ng:serve": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ng serve",
    "api": "node api-server.js",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ng build",
    "watch": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:mj_website": "node dist/mj_website/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.1.0",
    "@angular/common": "^17.1.0",
    "@angular/compiler": "^17.1.0",
    "@angular/core": "^17.1.0",
    "@angular/forms": "^17.1.0",
    "@angular/platform-browser": "^17.1.0",
    "@angular/platform-browser-dynamic": "^17.1.0",
    "@angular/platform-server": "^17.1.0",
    "@angular/router": "^17.1.0",
    "@angular/ssr": "^17.1.1",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.1.1",
    "@angular/cli": "^17.1.1",
    "@angular/compiler-cli": "^17.1.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^18.18.0",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "multer": "^2.2.0",
    "typescript": "~5.3.2"
  }
}
